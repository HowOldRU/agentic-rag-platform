# Django 后端配置

# ── 基础 ──────────────────────────────────────────────
SECRET_KEY=your-secret-key-change-me-in-production
DEBUG=True

# ── MySQL ─────────────────────────────────────────────
DB_NAME=django_backend
DB_USER=root
DB_PASSWORD=your_db_password
DB_HOST=127.0.0.1
DB_PORT=3306

# ── JWT ───────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=120
JWT_REFRESH_TOKEN_LIFETIME_DAYS=30

# ── CORS ──────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ── AI Service ────────────────────────────────────────
AI_SERVICE_BASE_URL=http://localhost:7729

# ── MinIO ─────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=your_minio_password
MINIO_SECURE=False
MINIO_BUCKET=knowledge-base
MINIO_GENERATED_BUCKET=generated-files
MINIO_CHAT_UPLOAD_BUCKET=chat-uploads
