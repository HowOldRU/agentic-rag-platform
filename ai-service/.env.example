# AI Service 配置

# ── vLLM 语言模型 (Qwen3.5) ──────────────────────────
VLLM_BASE_URL=http://localhost:3001
VLLM_MODEL_NAME=/models/Qwen3.5-9B
VLLM_TIMEOUT=600
VLLM_MAX_TOKENS=16384
VLLM_MAX_MODEL_LEN=40960
VLLM_TEMPERATURE=0.7

# ── vLLM 视觉模型 (Qwen2.5-VL) ──────────────────────
VLLM_VLM_BASE_URL=http://localhost:3002
VLLM_VLM_MODEL_NAME=/models/Qwen2.5-VL-7B-Instruct

# ── Django 后端 ──────────────────────────────────────
DJANGO_API_BASE_URL=http://localhost:8000
SERVICE_AUTH_TOKEN=

# ── MySQL ─────────────────────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_db_password
MYSQL_DATABASE=ai_service

# ── 合金计算数据库（可选）────────────────────────────
CALC_DB_HOST=localhost
CALC_DB_PORT=3306
CALC_DB_USER=root
CALC_DB_PASSWORD=your_db_password
CALC_DB_DATABASE=hejinshuju

# ── Elasticsearch ─────────────────────────────────────
ES_HOST=localhost
ES_PORT=9200
ES_USERNAME=elastic
ES_PASSWORD=your_es_password
ES_USE_SSL=False
KB_SERVICE_INDEX=kb_service

# ── Redis ─────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ── MinIO ─────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=your_minio_password
MINIO_SECURE=False
MINIO_BUCKET=knowledge-base
MINIO_GENERATED_BUCKET=generated-files
MINIO_CHAT_UPLOAD_BUCKET=chat-uploads

# ── Ollama Embedding (bge-m3) ────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_BGE_M3_MODEL=bge-m3
OLLAMA_TIMEOUT=900

# ── MinerU 文档解析（PDF 解析必需）─────────────────────
MINERU_API_URL=http://localhost:8010/file_parse
MINERU_API_TIMEOUT=600

# ── Reranker（可选）───────────────────────────────────
QA_ENABLE_RERANKER=True
RERANKER_BASE_URL=http://localhost:9997/v1
RERANKER_MODEL_NAME=bge-reranker-v2-m3
RERANKER_API_KEY=none
RERANKER_TIMEOUT=30
